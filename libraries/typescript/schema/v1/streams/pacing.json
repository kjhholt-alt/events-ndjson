{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://events-ndjson.dev/schema/v1/streams/pacing.json",
  "title": "pacing stream v1",
  "description": "Game/UX pacing events for telemetry-driven tuning",
  "type": "object",
  "additionalProperties": false,
  "required": ["scene"],
  "properties": {
    "scene": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "elapsed_ms": {
      "type": "integer",
      "minimum": 0
    },
    "interaction_count": {
      "type": "integer",
      "minimum": 0
    },
    "tag": {
      "type": "string",
      "maxLength": 64
    },
    "intensity": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "session_id": {
      "type": "string",
      "maxLength": 64
    }
  }
}
